# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration for Frontend Access
# Single frontend URL (backward compatible)
FRONTEND_URL=http://localhost:5173

# Multiple frontend URLs for multi-brigade support (comma-separated)
# Use this when brigades need to link from their own domains
# Example: FRONTEND_URLS=https://station-manager.bungendorerfs.org,https://brigade1.org,https://brigade2.org
# If FRONTEND_URLS is set, it takes precedence over FRONTEND_URL
# FRONTEND_URLS=http://localhost:5173
#
# StationKit suite: include the sibling apps' origins so the shared SSO
# cookie's cross-subdomain fetches (GET /api/auth/session) pass CORS.
# FRONTEND_URLS=https://stationkit.com.au,https://santa.stationkit.com.au,https://firebreak.stationkit.com.au

# ─────────────────────────────────────────────────────────────────────────────
# Suite SSO cookie (StationKit — sk_session)
# ─────────────────────────────────────────────────────────────────────────────
# Parent domain the SSO session cookie is scoped to, so signing in here also
# signs a user in on every *.stationkit.com.au sibling app (Fire Santa Run,
# Fire Break Calculator) without a redirect — see
# docs/wiki/developer/suite-token-validation.md. Leave unset for local dev
# (the cookie then defaults to the exact request host and won't cross ports).
# COOKIE_DOMAIN=.stationkit.com.au

# ─────────────────────────────────────────────────────────────────────────────
# Passkeys (WebAuthn) — additive to username/password
# ─────────────────────────────────────────────────────────────────────────────
# Relying Party ID: the shared parent domain, same idea as COOKIE_DOMAIN but
# WITHOUT the leading dot (WebAuthn's own convention). A passkey registered
# here can then be used to sign in directly from any *.stationkit.com.au
# sibling app's own login screen. Defaults to COOKIE_DOMAIN with the leading
# dot stripped; if neither is set, falls back per-request to the request's
# own hostname (so passkeys still work on a single app — cross-app sign-in
# needs this set explicitly to the shared parent domain).
# WEBAUTHN_RP_ID=stationkit.com.au
# WEBAUTHN_RP_NAME=StationKit

# Authentication Configuration
# When set to 'true', requires authentication for:
# - Station management endpoints (GET /api/stations, GET /api/stations/:id, etc.)
# - Brigade access token management
# - Station lookup endpoint
# Public users will only see the demo station when REQUIRE_AUTH=true
# Set to 'false' or omit to allow open access (default for development)
# REQUIRE_AUTH=true

# JWT Configuration (required when REQUIRE_AUTH=true)
# Change these values in production!
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# JWT_EXPIRY=24h

# Default Admin Account Configuration (required when REQUIRE_AUTH=true)
# These credentials are used to create the initial admin account on server startup
# ⚠️ CRITICAL: You MUST set both DEFAULT_ADMIN_USERNAME and DEFAULT_ADMIN_PASSWORD for authentication to work!
# If these are not set, no admin account will be created and login will fail.
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Azure Table Storage Configuration
# For production, use Azure Table Storage connection string
# Required for persistent data storage and truck check photos
# Set USE_TABLE_STORAGE=false to explicitly use in-memory database (development/testing only)
USE_TABLE_STORAGE=true
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# To get your Azure Storage connection string:
# az storage account show-connection-string --name <your-storage-account-name> --resource-group <your-resource-group> --query "connectionString" --output tsv

# Optional: Custom container names (defaults: reference-photos, result-photos)
# AZURE_STORAGE_REFERENCE_CONTAINER=reference-photos
# AZURE_STORAGE_RESULT_CONTAINER=result-photos

# Rate Limiting Configuration
# Protects API endpoints from abuse and DDoS attacks
# RATE_LIMIT_WINDOW_MS=300000        # 5 minutes in milliseconds (default: 300000)
# RATE_LIMIT_API_MAX=84              # Max requests per window for API routes (default: ~84 -> ≈1,000/hour)
# RATE_LIMIT_AUTH_MAX=5              # Max requests per window for auth routes (default: 5)

# Event Auto-Expiry Configuration
# Events automatically become inactive after this many hours
EVENT_EXPIRY_HOURS=12                # Hours after event start time (default: 12)

# Azure Application Insights (Optional)
# For centralized logging and monitoring with 1-day retention
# Recommended for production deployments
# Get connection string from Azure Portal: Application Insights → Overview → Connection String
# To configure 1-day retention: Settings → Usage and estimated costs → Data Retention = 1 day
# AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.applicationinsights.azure.com/

# ─────────────────────────────────────────────────────────────────────────────
# SaaS Entitlements (StationKit multi-tenancy)
# ─────────────────────────────────────────────────────────────────────────────
# Feature gating is ON by default. Requests with no organization context
# (kiosk/demo/plain JWT) always pass through regardless of this flag.
# Set to 'false' ONLY for single-tenant/kiosk local dev. NEVER disable in
# production — it removes all plan/billing enforcement.
# ENABLE_ENTITLEMENTS=false

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Billing (optional — checkout, customer portal, webhooks)
# ─────────────────────────────────────────────────────────────────────────────
# Test-mode keys from the Stripe dashboard. Leave unset to disable billing
# (signup falls back to the free Community plan, no checkout).
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx          # from `stripe listen` or the dashboard endpoint
# APP_URL=http://localhost:5173            # base URL for checkout success/cancel + portal return

# Stripe Price IDs per plan (create products/prices in the Stripe dashboard)
# STRIPE_PRICE_BASIC_MONTHLY=price_xxx
# STRIPE_PRICE_BASIC_ANNUAL=price_xxx
# STRIPE_PRICE_AI_MONTHLY=price_xxx
# STRIPE_PRICE_AI_ANNUAL=price_xxx

# AI session top-up pack (one-time purchase, D1 decision 2026-07-17: 25
# sessions for A$15 — create a `mode: payment` Price in the Stripe dashboard
# for that amount and set its id here). This is the only paid path past the
# included monthly allowance — AI usage hard-stops at 402 once
# aiIncludedSessions is exhausted (backend/src/routes/ai.ts), it does not
# roll into billed overage. (Decided 2026-07-18: a Stripe-metered-overage
# model was considered and rejected as a second billing path — see
# docs/wiki/developer/changelog.md.)
# STRIPE_PRICE_AI_TOPUP=price_xxx
# AI_TOPUP_PACK_SIZE=25

# Standalone Fire Santa Run add-on (Community orgs only — Basic/AI Pro already
# grant santaRunEnabled via the plan, see constants/plans.ts). Cheap and
# unlimited-use by design: A$10/year or A$15 for a one-off month, priced to
# nudge toward the annual. Create both as recurring Prices in the Stripe
# dashboard and set their ids here.
# STRIPE_PRICE_SANTA_ADDON_MONTHLY=price_xxx
# STRIPE_PRICE_SANTA_ADDON_ANNUAL=price_xxx

# ─────────────────────────────────────────────────────────────────────────────
# AI Gateway (server-side AI for AAR Studio — /api/ai/*)
# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI powers chat + report generation. Leave unset to disable AI
# features (the gateway returns a friendly "not configured" response).
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o-mini       # deployment name for chat
# AZURE_OPENAI_DEPLOYMENT_REPORT=gpt-4o          # deployment name for report generation
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Speech powers live transcription. The gateway vends short-lived tokens
# to the browser (keys never leave the server).
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=australiaeast

# ─────────────────────────────────────────────────────────────────────────────
# AAR Studio
# ─────────────────────────────────────────────────────────────────────────────
# Path to the aar-studio/ bundle served at /aar. Defaults to the sibling
# directory; override only for non-standard deploy layouts.
# AAR_STUDIO_PATH=../aar-studio

