{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run setup)",
      "Bash(npm run check)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run test:all)",
      "Bash(npm run build:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(bash scripts/check.sh)",
      "Bash(bash scripts/setup.sh)",
      "Bash(bash scripts/validate-registries.sh)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/setup.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
